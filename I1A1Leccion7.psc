Algoritmo I1A1Leccion7
	Definir n1, n2, n3, n4, n5 Como Real
	
	Escribir "Ingrese la nota 1"
	Leer n1
	Escribir "Ingrese la nota 2"
	Leer n2
	Escribir "Ingrese la nota 3"
	Leer n3
	Escribir "Ingrese la nota 4"
	Leer n4
	Escribir "Ingrese la nota 5"
	Leer n5
	
	si ((n1 + n2 + n3 + n4 +  n5) / 5) > 70 Entonces
		Escribir "Usted aprobo la materia"
	SiNo
		Escribir "Usted ha reprobado"
	FinSi
FinAlgoritmo
