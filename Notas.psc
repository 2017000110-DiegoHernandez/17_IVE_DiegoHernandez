Algoritmo Notas
	Definir letra Como Caracter
	Escribir "Calificacion de letras por rango"
	Escribir Sin Saltar "Digite una letra: "
	Leer letra
	
	Segun letra Hacer
		"A" o "a":
			Escribir "Excelente"
		"B" o "b":
			Escribir "BUENO"
		"C" o "c":
			Escribir "REGULAR"
		"D" o "d":
			Escribir "DEFICIENTE"
		"E" o "e":
			Escribir "REPROBADO"
		De Otro Modo:
			Escribir "ESCRIBA UNA LETRA DE A a E "
	Fin Segun
	
FinAlgoritmo
