Algoritmo I2A1Leccion7
	
	Definir e Como Real
	
	Escribir "Ingrese su edad."
	Leer e
	
	si e >= 18 Entonces
		Escribir "Usted es mayor de edad"
	FinSi
	
	si e == 18 Entonces
		Escribir "Usted es mayor de edad"
	FinSi
	
	si e < 18 Entonces
		Escribir "Usted es menor de edad"
	FinSi
	
	
FinAlgoritmo
